# Supabase project credentials.
# Get these from Supabase Dashboard → Project Settings → API.

# Public URL of the Supabase project (used by both server and client SDKs).
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co

# Public anon key (used by the browser SDK; safe to expose).
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# Service-role key (server-only — bypasses RLS for trusted writes).
# This MUST NOT appear in any client bundle. Next.js loads it from process.env
# in Route Handlers and Server Components.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
